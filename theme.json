{
	"$schema": "https://schemas.wp.org/wp/6.6/theme.json",
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"color": "#12a96a",
					"name": "Aposta Green",
					"slug": "aposta-green"
				},
				{
					"color": "#ffc700",
					"name": "Rating Yellow",
					"slug": "rating-yellow"
				},
				{
					"color": "#ff8f28",
					"name": "Bonus Orange",
					"slug": "bonus-orange"
				},
				{
					"color": "#1d2129",
					"name": "Ink",
					"slug": "ink"
				},
				{
					"color": "#f2f2f3",
					"name": "Soft Gray",
					"slug": "soft-gray"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "white"
				}
			]
		},
		"layout": {
			"contentSize": "1194px",
			"wideSize": "1194px"
		},
		"spacing": {
			"spacingSizes": [
				{
					"name": "4",
					"size": "4px",
					"slug": "4"
				},
				{
					"name": "8",
					"size": "8px",
					"slug": "8"
				},
				{
					"name": "12",
					"size": "12px",
					"slug": "12"
				},
				{
					"name": "16",
					"size": "16px",
					"slug": "16"
				},
				{
					"name": "24",
					"size": "24px",
					"slug": "24"
				},
				{
					"name": "32",
					"size": "32px",
					"slug": "32"
				},
				{
					"name": "48",
					"size": "48px",
					"slug": "48"
				},
				{
					"name": "64",
					"size": "64px",
					"slug": "64"
				}
			],
			"units": [ "%", "px", "em", "rem", "vh", "vw" ]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Roboto, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"name": "Roboto",
					"slug": "roboto"
				},
				{
					"fontFamily": "'Roboto Condensed', Roboto, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"name": "Roboto Condensed",
					"slug": "roboto-condensed"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"size": "13px",
					"slug": "small"
				},
				{
					"name": "Body",
					"size": "17px",
					"slug": "body"
				},
				{
					"name": "Lead",
					"size": "20px",
					"slug": "lead"
				},
				{
					"name": "Heading 3",
					"size": "24px",
					"slug": "heading-3"
				},
				{
					"name": "Heading 2",
					"size": "34px",
					"slug": "heading-2"
				},
				{
					"name": "Heading 1",
					"size": "64px",
					"slug": "heading-1"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"presets": [
				{
					"name": "Card",
					"shadow": "0 6px 18px rgba(29, 33, 41, .08)",
					"slug": "card"
				},
				{
					"name": "Elevated",
					"shadow": "0 14px 35px rgba(29, 33, 41, .14)",
					"slug": "elevated"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|white",
			"text": "var:preset|color|ink"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|roboto",
			"fontSize": "var:preset|font-size|body",
			"lineHeight": "1.6"
		},
		"blocks": {
			"core/paragraph": {
				"typography": {
					"fontSize": "var:preset|font-size|body",
					"lineHeight": "1.65"
				}
			},
			"core/heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|roboto-condensed",
					"fontWeight": "700",
					"lineHeight": "1.12"
				}
			},
			"core/button": {
				"border": {
					"radius": "4px"
				},
				"color": {
					"background": "var:preset|color|aposta-green",
					"text": "var:preset|color|white"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|roboto-condensed",
					"fontWeight": "700"
				}
			},
			"core/group": {
				"spacing": {
					"blockGap": "var:preset|spacing|24"
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": "var:preset|spacing|32"
				}
			},
			"core/table": {
				"border": {
					"color": "#d9dce1",
					"style": "solid",
					"width": "1px"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	],
	"version": 3
}
