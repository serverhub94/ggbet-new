{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "new-theme/data-table",
	"title": "Редактируемая таблица данных",
	"category": "new-theme",
	"icon": "editor-table",
	"textdomain": "new-theme",
	"style": "file:./style.css",
	"attributes": {
		"title": { "type": "string" },
		"background": { "type": "string" },
		"mobileBehavior": { "type": "string", "default": "scroll" },
		"highlightedRows": { "type": "array", "items": { "type": "number" }, "default": [] },
		"highlightedCells": { "type": "array", "items": { "type": "string" }, "default": [] },
		"headersText": { "type": "string" },
		"rowsText": { "type": "string" },
		"headers": {
			"type": "array",
			"items": { "type": "string" }
		},
		"rows": {
			"type": "array",
			"items": {
				"type": "array",
				"items": { "type": "string" }
			}
		}
	},
	"supports": {
		"html": false
	}
}
