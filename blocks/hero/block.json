{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "new-theme/hero",
	"title": "Hero",
	"category": "new-theme",
	"icon": "cover-image",
	"textdomain": "new-theme",
	"attributes": {
		"title": { "type": "string" },
		"text": { "type": "string" },
		"image": { "type": "string" },
		"imageId": { "type": "number" },
		"overlayColor": { "type": "string", "default": "#000000" },
		"overlayOpacity": { "type": "number", "default": 0 },
		"topSpacer": { "type": "number", "default": 48 },
		"variant": {
			"type": "string",
			"default": "dark",
			"enum": [ "dark", "light" ]
		}
	},
	"supports": {
		"html": false
	}
}
